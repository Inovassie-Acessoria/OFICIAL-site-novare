# ============================================================
#  Novare Brindes — Variáveis de ambiente (MODELO)
# ------------------------------------------------------------
#  Copie este arquivo para `.env.local` (desenvolvimento) ou
#  `.env` (produção) e preencha com valores reais.
#  NUNCA versione `.env` / `.env.local` — eles estão no .gitignore.
#  Em produção (Hostinger) você pode usar variáveis de ambiente
#  do painel em vez deste arquivo.
# ============================================================

# --- Aplicação ---
APP_ENV=local            # local | production
APP_DEBUG=true           # true em dev, false em produção
APP_URL=http://localhost:8000

# --- Banco de dados (MySQL / Hostinger) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=novare
DB_USER=novare_app
DB_PASSWORD=

# --- Google Gemini (proxy PHP — chave NUNCA vai ao frontend) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- API XBZ (sincronização semanal via cron) ---
XBZ_API_URL=https://api.minhaxbz.com.br:5001/api/clientes/GetListaDeProdutos
XBZ_CNPJ=
XBZ_TOKEN=

# --- Lead / WhatsApp comercial (somente dígitos: DDI+DDD+numero) ---
WHATSAPP_NUMBER=5511973939349

# --- Domínio final (usado na geração de links absolutos) ---
SITE_DOMAIN=novarebrindes.com.br
